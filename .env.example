APP_PORT=8080
APP_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=notifications
DB_SSLMODE=disable

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# webhook.site'tan kendi UUID'ini al: https://webhook.site
PROVIDER_WEBHOOK_URL=https://webhook.site/your-uuid-here

WORKER_CONCURRENCY=10
WORKER_RATE_LIMIT=100

TRACING_ENABLED=false
TRACING_SERVICE_NAME=notification-system
# Optional, for example: otel-collector:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
